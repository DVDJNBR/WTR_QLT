# ===================================================================
#  Water Quality Pipeline — Environment Variables
# ===================================================================
#
#  HOW TO POPULATE THIS FILE:
#  1. Copy to .env:          cp .env.example .env
#  2. Get Azure subscription: invoke get-subscription
#  3. Deploy infrastructure: invoke azure-deploy
#  4. Fetch all outputs:     invoke env-save
#     → auto-fills AZURE_SUBSCRIPTION_ID, DATALAKE_*, DATABRICKS_WORKSPACE_URL, RESOURCE_GROUP_NAME
#
#  Only DATABRICKS_TOKEN requires a manual step:
#  → Databricks workspace > User Settings > Developer > Access Tokens > Generate new token
#
# ===================================================================

#  AZURE CREDENTIALS
AZURE_SUBSCRIPTION_ID=

#  DATA LAKE STORAGE  (auto-populated by `invoke env-save`)
DATALAKE_NAME=
DATALAKE_ACCESS_KEY=
DATALAKE_CONNECTION_STRING=

#  DATABRICKS WORKSPACE  (auto-populated by `invoke env-save`)
DATABRICKS_WORKSPACE_URL=

#  DATABRICKS AUTH  (manual — create in Databricks > User Settings > Access Tokens)
DATABRICKS_TOKEN=

#  DATABRICKS PATHS  (optional — default used if not set)
DATABRICKS_NOTEBOOKS_PATH=/Repos/main/WTR_QLT/notebooks

#  AZURE RESOURCES  (auto-populated by `invoke env-save`)
RESOURCE_GROUP_NAME=
